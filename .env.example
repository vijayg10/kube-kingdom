# Kube City — environment configuration
# Copy to `.env` and adjust as needed. All values below are the defaults.

# true = synthetic demo cluster, false = connect to a real Kubernetes cluster
MOCK_MODE=true

# true = observe only (no mutations), false = enable restart/scale/delete actions
READ_ONLY=true

# Path to kubeconfig (only used when MOCK_MODE=false). A kubeconfig may also be
# pasted at runtime via the Connect Cluster screen — it is held in memory only.
KUBECONFIG=~/.kube/config

# Backend HTTP + WebSocket port
PORT=3001

# WebSocket URL the frontend connects to (Vite env — must be VITE_ prefixed)
VITE_WS_URL=ws://localhost:3001
